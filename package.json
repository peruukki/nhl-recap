{
  "name": "nhl-recap",
  "version": "1.64.38",
  "type": "module",
  "description": "Play back the goal information from the latest NHL games.",
  "keywords": ["NHL", "scores", "cyclejs"],
  "author": "Harri Lehtola <peruukki@hotmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peruukki/nhl-recap.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.0"
  },
  "config": {
    "rollup_sw_args": "app/src/service-worker/service-worker.js -c --file public/service-worker.js --bundleConfigAsCjs"
  },
  "scripts": {
    "biome": "biome",
    "browserify": "browserify $npm_package_config_browserify_args -g uglifyify | uglifyjs -c -o public/main.js",
    "build": "npm run build:app && npm run build:sw",
    "build:app": "npm run ts && vite build",
    "build:sw": "rollup $npm_package_config_rollup_sw_args",
    "check": "concurrently -n check:js,lint:css,types,test \"npm run biome ci\" \"npm run lint:css\" \"npm run ts\" \"npm run test\"",
    "clean:dist": "cd dist && git fetch origin && git reset --hard origin/gh-pages && rm -rf *",
    "clone:dist": "[ -d 'dist' ] || git clone -b gh-pages --single-branch git@github.com:peruukki/nhl-recap.git dist",
    "commit:dist": "cd dist && git add -A . && git commit -m \"Version $npm_package_version\"",
    "copy:dist": "cp -r public/* dist",
    "copy:normalize": "mkdir -p app/styles/vendor && cp node_modules/normalize.css/normalize.css app/styles/vendor",
    "lint": "concurrently -n css,js \"npm run lint:css\" \"npm run lint:js\"",
    "lint:css": "stylelint --cache '**/*.scss'",
    "lint:js": "biome lint",
    "format": "biome format --write",
    "format:check": "biome format",
    "postinstall": "npm run copy:normalize",
    "deploy": "npm run build && npm run clone:dist && npm run clean:dist && npm run copy:dist && npm run commit:dist && npm run push:dist",
    "push:dist": "cd dist && git push origin gh-pages",
    "scale-team-logos": "node tools/analyze-logo-weights.ts",
    "postscale-team-logos": "cp tools/logo-analysis/logo-scales.scss app/src/components/team-logo-scales.scss",
    "start": "VITE_DEBUG=true vite --no-open",
    "start:local": "VITE_SCORE_API_HOST=http://localhost:8080 npm start",
    "start:production": "npm run build && vite preview",
    "start:server": "json-server server/db.json --routes server/routes.json --port 8080 --host 0.0.0.0 --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ts": "tsgo",
    "ts:watch": "tsgo --watch"
  },
  "dependencies": {
    "@cycle/dom": "23.1.0",
    "@cycle/http": "15.4.0",
    "@cycle/run": "5.7.0",
    "classnames": "2.5.1",
    "lodash": "4.17.23",
    "normalize.css": "8.0.1",
    "snabby": "6.1.1",
    "timeago.js": "4.0.2",
    "workbox-expiration": "7.4.0",
    "workbox-precaching": "7.4.0",
    "workbox-routing": "7.4.0",
    "workbox-strategies": "7.4.0",
    "xstream": "11.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@types/lodash": "4.17.21",
    "@typescript/native-preview": "7.0.0-dev.20260218.1",
    "@vitest/coverage-v8": "4.0.13",
    "autoprefixer": "10.4.22",
    "baseline-browser-mapping": "2.9.19",
    "concurrently": "9.2.1",
    "globals": "16.5.0",
    "json-server": "0.17.4",
    "monotone-chain-convex-hull": "1.1.0",
    "nock": "14.0.10",
    "rollup": "4.59.0",
    "rollup-plugin-terser": "7.0.2",
    "rollup-plugin-workbox-inject": "2.0.0",
    "sass": "1.94.2",
    "sharp": "0.33.5",
    "stylelint": "16.26.0",
    "stylelint-config-standard-scss": "16.0.0",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vitest": "4.0.13"
  },
  "private": true
}
